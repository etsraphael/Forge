{
  "name": "forge",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:host": "concurrently \"npm run dev:server\" \"npm run dev --prefix forge-fe -- --host\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "npm run dev --prefix forge-fe",
    "build": "npm run build --prefix forge-fe",
    "start": "NODE_ENV=production node server/index.js",
    "lint": "eslint . && npm run lint --prefix forge-fe",
    "lint:fix": "eslint . --fix && npm run lint:fix --prefix forge-fe",
    "format": "prettier --write \"server/**/*.js\" && npm run format --prefix forge-fe",
    "format:check": "prettier --check \"server/**/*.js\" && npm run format:check --prefix forge-fe"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.79",
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1"
  }
}
